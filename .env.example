# Copy to .env for local dev. Production builds use the same variables from GitHub Actions secrets.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional; defaults to us-central1 in src/lib/firebase.js
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Optional; connect to local Firebase emulators in dev
# VITE_USE_FIREBASE_EMULATORS=true

# Cloudflare Worker endpoint that returns a presigned PUT URL for R2.
# Example: https://r2-signer.your-subdomain.workers.dev
VITE_R2_SIGNER_URL=

# Firebase Functions (Google Cloud console → Cloud Run → each function → Variables & secrets, or deploy-time env):
# R2 S3 API credentials (same bucket as the Worker). Used for zip export and presigned gallery downloads.
# Option A: plain env in Cloud Run console. Option B: Firebase secrets (names must match exactly), then redeploy:
# Option B: Firebase secrets (names must match exactly), then redeploy functions:
#   firebase functions:secrets:set R2_ACCOUNT_ID
#   firebase functions:secrets:set R2_BUCKET_NAME
#   firebase functions:secrets:set R2_ACCESS_KEY_ID
#   firebase functions:secrets:set R2_SECRET_ACCESS_KEY
# Values: Cloudflare dashboard → R2 → your bucket; account id in bucket / API URL; keys from
# R2 → Overview → "Manage R2 API Tokens" (Object Read & Write on this bucket — same idea as Worker).
# R2_ACCOUNT_ID=
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Public URL base for rendering images from R2 (custom domain or r2.dev).
VITE_R2_PUBLIC_BASE_URL=

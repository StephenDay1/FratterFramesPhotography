# Copy to .env for local dev. Production builds use the same variables from GitHub Actions secrets.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional; defaults to us-central1 in src/lib/firebase.js
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Optional; connect to local Firebase emulators in dev
# VITE_USE_FIREBASE_EMULATORS=true

# Cloudflare Worker endpoint (uploads, deletes, storage usage).
# Example: https://r2-signer.your-subdomain.workers.dev
VITE_R2_SIGNER_URL=

# Firebase Functions (Google Cloud console → Cloud Run → each function → Variables & secrets, or deploy-time env):
# R2 S3 API credentials (same bucket as the Worker). Used for presigned downloads and server-side thumbnails.
#   firebase functions:secrets:set R2_ACCOUNT_ID
#   firebase functions:secrets:set R2_BUCKET_NAME
#   firebase functions:secrets:set R2_ACCESS_KEY_ID
#   firebase functions:secrets:set R2_SECRET_ACCESS_KEY
# R2_ACCOUNT_ID=
# R2_BUCKET_NAME=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=

# Download-all builds a zip in the browser (presigned GET per photo). The R2 bucket needs CORS so fetch() works:
# Cloudflare dashboard → R2 → your bucket → Settings → CORS policy, e.g. allow GET from your site origins:
#   AllowedOrigins: https://fratterframesphotography.web.app, https://fratterframesphotography.firebaseapp.com, http://localhost:5173
#   AllowedMethods: GET, HEAD
#   AllowedHeaders: *

# Public URL base for rendering images from R2 (custom domain or r2.dev).
VITE_R2_PUBLIC_BASE_URL=

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /** Set via Admin SDK: auth.setCustomUserClaims(uid, { admin: true }) */
    function isGalleryAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    match /galleries/{galleryId} {
      allow read: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || isGalleryAdmin());
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if request.auth != null
        && request.resource.data.ownerUid == resource.data.ownerUid
        && (resource.data.ownerUid == request.auth.uid || isGalleryAdmin());
      allow delete: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid || isGalleryAdmin());

      match /photos/{photoId} {
        allow get: if request.auth != null && (
          request.auth.token.galleryId == galleryId
          || resource.data.ownerUid == request.auth.uid
          || isGalleryAdmin()
        );
        allow list: if request.auth != null && (
          request.auth.token.galleryId == galleryId
          || get(/databases/$(database)/documents/galleries/$(galleryId)).data.ownerUid == request.auth.uid
          || isGalleryAdmin()
        );
        allow create: if request.auth != null
          && request.resource.data.ownerUid == request.auth.uid
          && (
            get(/databases/$(database)/documents/galleries/$(galleryId)).data.ownerUid == request.auth.uid
            || isGalleryAdmin()
          );
        allow update, delete: if request.auth != null
          && (resource.data.ownerUid == request.auth.uid || isGalleryAdmin());
      }

      /** Zip export jobs: created/updated only by Cloud Functions (Admin SDK). Clients may read status. */
      match /zipJobs/{jobId} {
        allow read: if request.auth != null && (
          request.auth.token.galleryId == galleryId
          || get(/databases/$(database)/documents/galleries/$(galleryId)).data.ownerUid == request.auth.uid
          || isGalleryAdmin()
        );
        allow create, update, delete: if false;
      }
    }
  }
}

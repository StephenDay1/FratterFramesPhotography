rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Gallery root: only the owner (your Firebase Auth account) can read/write metadata.
    match /galleries/{galleryId} {
      allow read: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;

      // Photos: owner manages; viewers authenticate via custom token from verifyGalleryKey.
      match /photos/{photoId} {
        allow read: if request.auth != null && (
          request.auth.token.galleryId == galleryId
          || resource.data.ownerUid == request.auth.uid
        );
        allow create: if request.auth != null
          && get(/databases/$(database)/documents/galleries/$(galleryId)).data.ownerUid == request.auth.uid
          && request.resource.data.ownerUid == request.auth.uid;
        allow update, delete: if request.auth != null
          && resource.data.ownerUid == request.auth.uid;
      }
    }
  }
}
